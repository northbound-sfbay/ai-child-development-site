---
interface Props {
  active: "roadmap" | "newsletter";
}

const { active } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const tabs = [
  { key: "roadmap", label: "Roadmap", href: base },
  { key: "newsletter", label: "Newsletter", href: `${base}newsletter/` }
] as const;
---

<header class="site-topbar" aria-label="Primary site navigation">
  <div class="site-topbar-inner">
    <a class="site-brand" href={base}>
      <span>AI + Child Development</span>
      <span>Research radar</span>
    </a>
    <nav class="site-tabs" aria-label="Site sections">
      {
        tabs.map((tab) => (
          <a
            href={tab.href}
            class={`site-tab${active === tab.key ? " is-active" : ""}`}
            aria-current={active === tab.key ? "page" : undefined}
          >
            {tab.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
