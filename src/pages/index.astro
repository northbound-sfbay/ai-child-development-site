---
import BaseLayout from "../layouts/BaseLayout.astro";
import FramingNote from "../content/framing.mdx";
import { sources } from "../data/sources";
import siteData from "../../ai_child_development_site_data.json";

const navItems = [
  ["hero", "Hero"],
  ["why", "Why this matters"],
  ["roadmap-goal", "Roadmap Goal"],
  ["bottlenecks", "Bottlenecks"],
  ["field-map", "Field Map"],
  ["research-density", "Research Density"],
  ["program-template", "Program Template"],
  ["priority-portfolio", "Priority Portfolio"],
  ["catalytic-programs", "Catalytic Programs"],
  ["landscape", "Landscape"],
  ["open-questions", "Open Questions"],
  ["sources", "Sources"]
];

const domainTones = [
  {
    key: "neural",
    label: "Physical / Neural",
    swatch: "#6f8fb7"
  },
  {
    key: "cognitive",
    label: "Cognitive / Executive Function",
    swatch: "#7c6fb0"
  },
  {
    key: "language",
    label: "Language / Literacy",
    swatch: "#2f9f8f"
  },
  {
    key: "social",
    label: "Social Development",
    swatch: "#7aa95c"
  },
  {
    key: "emotional",
    label: "Emotional Regulation",
    swatch: "#d5964b"
  },
  {
    key: "identity",
    label: "Identity / Moral Development",
    swatch: "#b66a83"
  },
  {
    key: "learning",
    label: "Learning / Education",
    swatch: "#5b90b8"
  }
];

const fieldAxes = [
  {
    title: "Developmental period",
    body: "Anchor every question in the age window where exposure occurs and where effects may later emerge.",
    items: siteData.periods
  },
  {
    title: "Developmental domain",
    body: "Separate physical, cognitive, language, social, emotional, identity, and learning outcomes.",
    items: siteData.domains
  },
  {
    title: "Level of analysis",
    body: "Link product exposure to behavior, relationships, institutions, neural systems, and culture.",
    items: ["Child", "Dyad", "Family", "Classroom", "Platform", "Policy"]
  },
  {
    title: "Context",
    body: "Distinguish home, school, peer, clinical, community, and platform-mediated use.",
    items: ["Home", "School", "Peers", "Clinical", "Community", "Platform"]
  },
  {
    title: "Research method",
    body: "Match the question to observational, experimental, audit, longitudinal, and participatory methods.",
    items: ["Longitudinal", "RCT", "Diary", "Audit", "Interview", "Product telemetry"]
  }
];

const roadmapGoalPillars = [
  {
    label: "Big if true",
    title: "A rigorous field for child-AI evidence",
    body: "What if child-facing AI could be measured, audited, compared, and studied longitudinally across age, context, and developmental domain?"
  },
  {
    label: "Success state",
    title: "Comparable evidence instead of isolated claims",
    body: "Researchers, schools, families, product teams, and policymakers can evaluate AI systems against shared exposure, mechanism, outcome, and evidence standards."
  },
  {
    label: "Roadmap horizon",
    title: "A 3-5 year research infrastructure agenda",
    body: "The goal is not one definitive answer. It is a coordinated path toward cohorts, testbeds, measures, audits, and causal designs that make answers possible."
  }
];

const bottlenecks = [
  {
    title: "Exposure measurement",
    current: "AI use is not a single behavior: children may encounter tutoring, companionship, search, writing help, voice interfaces, classroom tools, recommendation systems, and AI-generated media.",
    unlock: "A shared exposure vocabulary would let studies compare dose, modality, agency, duration, and adult involvement."
  },
  {
    title: "Product opacity",
    current: "Many child-facing AI systems change quickly, personalize responses, and expose little about prompts, guardrails, retrieval sources, or recommendation loops.",
    unlock: "Audit protocols and product logs would make invisible system behavior legible enough for independent research."
  },
  {
    title: "Longitudinal evidence",
    current: "Most near-term evidence will be cross-sectional, short-run, or classroom-bound, while developmental effects may cascade over months or years.",
    unlock: "Panel studies and cohort add-ons would connect repeated AI exposure to developmental trajectories rather than isolated outcomes."
  },
  {
    title: "Causal designs outside education",
    current: "AI tutoring and school tools are easier to test than companionship, identity formation, family routines, sleep, help-seeking, or peer interaction.",
    unlock: "Ethical field experiments, natural experiments, and quasi-experimental designs would move the frontier beyond academic performance."
  },
  {
    title: "Age-specific outcome measures",
    current: "The same AI interaction may mean different things for toddlers, middle-school students, and adolescents, but measurement often flattens age and context.",
    unlock: "Age-banded measure batteries would let studies ask developmentally precise questions."
  },
  {
    title: "Governance and consent",
    current: "Child data, platform access, parental permission, school procurement, and clinical risk make AI-child research hard to run and hard to replicate.",
    unlock: "Shared governance templates would reduce friction while protecting children, families, teachers, and vulnerable groups."
  }
];

const researchProgramSteps = [
  {
    title: "Start with the cell",
    body: "Name the developmental period, domain, focal behavior, context, and baseline methods before adding an AI claim."
  },
  {
    title: "Specify the exposure",
    body: "Distinguish tutor, chatbot, companion, classroom AI, creative tool, AI toy, voice assistant, or invisible platform system."
  },
  {
    title: "Declare the mechanism",
    body: "State whether AI is expected to scaffold, displace, reinforce, model, offload, personalize, substitute socially, or shape identity."
  },
  {
    title: "Choose outcomes and evidence",
    body: "Tie the mechanism to validated outcomes, evidence tier, research design, measurement limits, and decision relevance."
  },
  {
    title: "Name the next study",
    body: "End each cell with a concrete next study: cohort add-on, audit, RCT, diary study, qualitative fieldwork, or policy evaluation."
  }
];

const catalyticPrograms = [
  {
    name: "Child-AI Exposure Cohort",
    horizon: "3-5 years",
    unlock: "Connect repeated AI exposure to language, learning, social, emotional, sleep, and identity trajectories.",
    build: ["Exposure diary plus passive logs", "Age-banded outcome batteries", "Family, school, and platform context measures"]
  },
  {
    name: "AI Companion Safety Testbed",
    horizon: "18-36 months",
    unlock: "Evaluate teen companion systems for dependency risk, boundary confusion, help-seeking, crisis behavior, and social substitution.",
    build: ["Red-team scripts", "Longitudinal teen panels", "Clinical escalation and consent protocols"]
  },
  {
    name: "Classroom AI Causal Trial Network",
    horizon: "2-4 years",
    unlock: "Separate learning gains from answer generation, teacher displacement, motivation shifts, and equity effects.",
    build: ["Multi-site classroom trials", "Teacher-in-the-loop conditions", "Common achievement and reasoning measures"]
  },
  {
    name: "Child-Facing AI Audit Infrastructure",
    horizon: "12-24 months",
    unlock: "Make system behavior inspectable across prompts, ages, languages, safety cases, personalization, and recommendation loops.",
    build: ["Age-role prompt suites", "Behavioral logging standards", "Public audit reports and benchmarks"]
  },
  {
    name: "AI Literacy Assessment Battery",
    horizon: "12-30 months",
    unlock: "Track whether children can identify AI, calibrate trust, detect misinformation, understand authorship, and use AI responsibly by age.",
    build: ["Developmentally staged tasks", "School-ready assessments", "Cross-cultural validation"]
  }
];

const openQuestionGroups = [
  {
    title: "Near-term answerable questions",
    questions: [
      "Which AI tutoring configurations improve learning without replacing reasoning?",
      "Can children identify AI-generated misinformation and synthetic authority cues by age?",
      "How do caregivers, teachers, and peers mediate everyday child-AI use?"
    ]
  },
  {
    title: "Infrastructure-dependent questions",
    questions: [
      "What does repeated AI companionship do to help-seeking, social avoidance, identity, and emotional regulation?",
      "How can researchers audit child-facing systems whose behavior changes through personalization and model updates?",
      "What shared exposure metrics can support comparisons across home, school, clinical, and platform contexts?"
    ]
  },
  {
    title: "Long-horizon developmental questions",
    questions: [
      "Do AI interactions produce developmental cascades across childhood and adolescence?",
      "How are neurodivergent, multilingual, low-resource, and otherwise vulnerable groups affected differently?",
      "What human interactions are displaced, complemented, or transformed when AI becomes routine infrastructure?"
    ]
  }
];

const formula = siteData.researchDensity.scoreFormula;
const tierLabels = siteData.researchDensity.tierLabels;
const densityMatrix = siteData.researchDensity.matrix;
const fieldMap = siteData.fieldMap;
const tierLabel = (tier: number) => tierLabels[String(tier) as keyof typeof tierLabels].label;
const tierMeaning = (tier: number) => tierLabels[String(tier) as keyof typeof tierLabels].meaning;
const densitySubscoreMatrix = [
  [
    { publicationVolume: 5, evidenceMaturity: 5, recentMomentum: 4 },
    { publicationVolume: 2, evidenceMaturity: 2, recentMomentum: 2 },
    { publicationVolume: 2, evidenceMaturity: 2, recentMomentum: 2 },
    { publicationVolume: 3, evidenceMaturity: 3, recentMomentum: 2 },
    { publicationVolume: 4, evidenceMaturity: 4, recentMomentum: 3 },
    { publicationVolume: 1, evidenceMaturity: 1, recentMomentum: 1 },
    { publicationVolume: 3, evidenceMaturity: 3, recentMomentum: 2 }
  ],
  [
    { publicationVolume: 5, evidenceMaturity: 5, recentMomentum: 4 },
    { publicationVolume: 4, evidenceMaturity: 4, recentMomentum: 4 },
    { publicationVolume: 5, evidenceMaturity: 5, recentMomentum: 4 },
    { publicationVolume: 5, evidenceMaturity: 5, recentMomentum: 4 },
    { publicationVolume: 4, evidenceMaturity: 4, recentMomentum: 3 },
    { publicationVolume: 2, evidenceMaturity: 2, recentMomentum: 2 },
    { publicationVolume: 3, evidenceMaturity: 3, recentMomentum: 3 }
  ],
  [
    { publicationVolume: 4, evidenceMaturity: 4, recentMomentum: 3 },
    { publicationVolume: 5, evidenceMaturity: 5, recentMomentum: 4 },
    { publicationVolume: 5, evidenceMaturity: 5, recentMomentum: 5 },
    { publicationVolume: 5, evidenceMaturity: 5, recentMomentum: 4 },
    { publicationVolume: 5, evidenceMaturity: 5, recentMomentum: 4 },
    { publicationVolume: 4, evidenceMaturity: 4, recentMomentum: 4 },
    { publicationVolume: 5, evidenceMaturity: 5, recentMomentum: 5 }
  ],
  [
    { publicationVolume: 4, evidenceMaturity: 4, recentMomentum: 3 },
    { publicationVolume: 5, evidenceMaturity: 5, recentMomentum: 5 },
    { publicationVolume: 5, evidenceMaturity: 5, recentMomentum: 5 },
    { publicationVolume: 5, evidenceMaturity: 5, recentMomentum: 5 },
    { publicationVolume: 5, evidenceMaturity: 5, recentMomentum: 5 },
    { publicationVolume: 4, evidenceMaturity: 4, recentMomentum: 4 },
    { publicationVolume: 5, evidenceMaturity: 5, recentMomentum: 5 }
  ],
  [
    { publicationVolume: 5, evidenceMaturity: 5, recentMomentum: 4 },
    { publicationVolume: 4, evidenceMaturity: 4, recentMomentum: 5 },
    { publicationVolume: 3, evidenceMaturity: 3, recentMomentum: 4 },
    { publicationVolume: 5, evidenceMaturity: 5, recentMomentum: 5 },
    { publicationVolume: 5, evidenceMaturity: 5, recentMomentum: 5 },
    { publicationVolume: 5, evidenceMaturity: 5, recentMomentum: 5 },
    { publicationVolume: 5, evidenceMaturity: 5, recentMomentum: 5 }
  ]
];
const subscoreFields = [
  {
    key: "publicationVolume",
    label: "Publication volume",
    weight: formula.publicationVolume,
    question: "How broad is the direct and adjacent literature base for this period-domain cell?"
  },
  {
    key: "evidenceMaturity",
    label: "Evidence maturity",
    weight: formula.evidenceMaturity,
    question: "Are there validated constructs, longitudinal or causal designs, reviews, measures, and convergent findings?"
  },
  {
    key: "recentMomentum",
    label: "Recent momentum",
    weight: formula.recentMomentum,
    question: "Is current work active in AI, digital media, HCI, policy, education, or youth-development venues?"
  }
];
const sourceByTitle = new Map(sources.map((source) => [source.title, source]));
const sourceRef = (title: string) => {
  const source = sourceByTitle.get(title);

  if (!source) {
    return {
      title,
      organization: "Source pending",
      year: "",
      url: "#",
      category: "Uncategorized",
      evidenceRole: "Source record needs to be added."
    };
  }

  return {
    title: source.title,
    organization: source.organization,
    year: source.year,
    url: source.url,
    category: source.category,
    evidenceRole: source.evidenceRole
  };
};
const periodSourceTitles = [
  ["Center on the Developing Child", "Child Development and Early Learning", "Developmental Sciences (DS)"],
  ["Center on the Developing Child", "Child Development and Early Learning", "Society for Research in Child Development"],
  ["Child Development and Early Learning", "Society for Research in Child Development", "Interaction Design and Children"],
  ["Society for Research in Child Development", "Children and Screens", "National Literacy Trust"],
  ["Health advisory on social media use in adolescence", "How Teens Use and View AI", "Common Sense Research"]
];
const domainSourceTitles = [
  ["Developmental Sciences (DS)", "Center on the Developing Child", "Child Development and Early Learning"],
  ["Developmental Sciences (DS)", "Child Development and Early Learning", "Society for Research in Child Development"],
  ["Child Development and Early Learning", "National Literacy Trust", "Society for Research in Child Development"],
  ["Society for Research in Child Development", "Children and Screens", "Common Sense Research"],
  ["Health advisory on social media use in adolescence", "Center on the Developing Child", "Children and Screens"],
  ["Society for Research in Child Development", "AI for Children", "Health advisory on social media use in adolescence"],
  ["International AIED Society Conferences", "National Literacy Trust", "Child Development and Early Learning"]
];
const momentumSourceTitles = [
  ["Developmental Sciences (DS)", "Center on the Developing Child"],
  ["Interaction Design and Children", "Children and Screens"],
  ["Interaction Design and Children", "National Literacy Trust", "Common Sense Research"],
  ["Children and Screens", "Common Sense Research", "International AIED Society Conferences"],
  ["How Teens Use and View AI", "Common Sense Research", "AI for Children", "Health advisory on social media use in adolescence"]
];
const unique = <T,>(items: T[]) => Array.from(new Set(items));
const roundedComposite = (subscores: Record<string, number>) =>
  Number(
    (
      subscores.publicationVolume * formula.publicationVolume +
      subscores.evidenceMaturity * formula.evidenceMaturity +
      subscores.recentMomentum * formula.recentMomentum
    ).toFixed(1)
  );
const bandLabel = (score: number) => {
  if (score >= 5) return "very strong";
  if (score >= 4) return "strong";
  if (score >= 3) return "moderate";
  if (score >= 2) return "limited";
  return "sparse";
};
const cellSourceTitles = (periodIndex: number, domainIndex: number) =>
  unique([
    ...periodSourceTitles[periodIndex],
    ...domainSourceTitles[domainIndex],
    ...momentumSourceTitles[periodIndex],
    ...(domainIndex === 6 ? ["International AIED Society Conferences", "National Literacy Trust"] : []),
    ...(domainIndex === 2 ? ["National Literacy Trust"] : []),
    ...(domainIndex >= 3 && periodIndex >= 3 ? ["Common Sense Research", "How Teens Use and View AI"] : []),
    ...(domainIndex === 5 ? ["AI for Children"] : [])
  ]).slice(0, 6);
const subscoreSourceTitles = (periodIndex: number, domainIndex: number, key: string) => {
  if (key === "publicationVolume") {
    return unique([...periodSourceTitles[periodIndex], ...domainSourceTitles[domainIndex]]).slice(0, 3);
  }

  if (key === "evidenceMaturity") {
    return unique([
      ...domainSourceTitles[domainIndex],
      "Developmental Sciences (DS)",
      "Society for Research in Child Development"
    ]).slice(0, 3);
  }

  return unique([
    ...momentumSourceTitles[periodIndex],
    ...(domainIndex === 6 ? ["International AIED Society Conferences", "National Literacy Trust"] : []),
    ...(domainIndex === 2 ? ["National Literacy Trust"] : []),
    ...(domainIndex >= 3 ? ["Common Sense Research"] : [])
  ]).slice(0, 3);
};
const evidenceCaveat = (tier: number, periodIndex: number, domainIndex: number) => {
  if (tier >= 5) {
    return "High baseline maturity does not mean child-AI effects are already settled; it means this cell has strong constructs and methods to support AI-specific studies.";
  }

  if (tier <= 2) {
    return "This cell needs direct database review before being used as a firm claim; current scoring is a directional prior based on adjacent developmental and technology literature.";
  }

  if (periodIndex === 4 || domainIndex >= 3) {
    return "Momentum is high because AI and digital-media questions are active, but causal and longitudinal child-AI evidence is still uneven.";
  }

  return "This score should be treated as a curated starting point until a formal bibliometric search is run.";
};
const auditQuery = (period: string, domain: string) =>
  `"${period}" "${domain}" child development (AI OR "artificial intelligence" OR "digital media" OR technology) (longitudinal OR review OR randomized OR cohort OR assessment)`;
const densityEvidenceCells = densityMatrix.flatMap((row, rowIndex) =>
  row.map((tier, colIndex) => {
    const period = siteData.periods[rowIndex];
    const domain = siteData.domains[colIndex];
    const subscores = densitySubscoreMatrix[rowIndex][colIndex];
    const composite = roundedComposite(subscores);

    return {
      id: `${rowIndex}-${colIndex}`,
      period,
      domain,
      tier,
      tierLabel: tierLabel(tier),
      tierMeaning: tierMeaning(tier),
      composite,
      confidence: tier >= 4 ? "Higher baseline confidence" : tier >= 3 ? "Moderate confidence" : "Low direct-evidence confidence",
      caveat: evidenceCaveat(tier, rowIndex, colIndex),
      auditQuery: auditQuery(period, domain),
      summary: `${period} x ${domain} is scored as tier ${tier} (${tierLabel(tier)}) from a weighted blend of curated publication-volume, evidence-maturity, and recent-momentum signals.`,
      subscores: subscoreFields.map((field) => {
        const score = subscores[field.key as keyof typeof subscores];

        return {
          key: field.key,
          label: field.label,
          weight: field.weight,
          score,
          weighted: Number((score * field.weight).toFixed(1)),
          question: field.question,
          rationale:
            field.key === "publicationVolume"
              ? `${score}/5 indicates ${bandLabel(score)} breadth of baseline and adjacent literature for this age-domain pairing. This is currently curated from source coverage, not a live database count.`
              : field.key === "evidenceMaturity"
                ? `${score}/5 indicates ${bandLabel(score)} maturity of constructs, measures, review traditions, and study designs available for this cell.`
                : `${score}/5 indicates ${bandLabel(score)} current activity in AI, digital-media, HCI, policy, education, or youth-development sources relevant to this cell.`,
          sources: subscoreSourceTitles(rowIndex, colIndex, field.key).map(sourceRef)
        };
      }),
      sources: cellSourceTitles(rowIndex, colIndex).map(sourceRef),
      validationNeeds: [
        "Run database searches with controlled vocabulary in PsycINFO, PubMed, ERIC, Scopus/Web of Science, and OpenAlex.",
        "Separate baseline developmental evidence from AI-specific evidence before upgrading the tier.",
        "Document inclusion criteria, study quality, sample age range, design type, and recency for each cited source."
      ]
    };
  })
);
const sourceCategories = ["All", ...Array.from(new Set(sources.map((source) => source.category)))];
const sourceSearchText = (source: (typeof sources)[number]) =>
  [
    source.title,
    source.organization,
    source.year,
    source.category,
    source.evidenceRole,
    source.whyItMatters,
    ...source.tags
  ]
    .join(" ")
    .toLowerCase();
const title = `${siteData.title} | Research Landscape`;
const description = siteData.subtitle;
---

<BaseLayout title={title} description={description}>
  <div class="site-shell">
    <div class="page-grid">
      <aside class="toc" aria-label="Section navigation">
        <nav class="flex gap-2 p-3 text-sm lg:block lg:space-y-1 lg:p-4">
          {
            navItems.map(([href, label]) => (
              <a
                href={`#${href}`}
                class="inline-flex rounded-sm px-3 py-2 font-semibold text-slate-700 transition hover:bg-slate-100 hover:text-navy focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-teal lg:flex"
              >
                {label}
              </a>
            ))
          }
        </nav>
      </aside>

      <main>
        <section id="hero" class="py-8 sm:py-10 lg:py-12">
          <div class="grid gap-8">
            <div class="max-w-5xl">
              <p class="section-kicker">01 / Developmental science strategy brief</p>
              <h1 class="mt-4 max-w-5xl font-serif text-[clamp(2.6rem,6.4vw,5.8rem)] font-bold leading-[0.94] tracking-normal text-navy">
                {siteData.title}
              </h1>
              <p class="mt-5 max-w-3xl text-lg leading-7 text-slate-600 sm:text-xl sm:leading-8">
                {siteData.subtitle}
              </p>
            </div>

            <div class="grid gap-4 border-y border-line py-4 md:grid-cols-3">
              <div>
                <p class="text-sm font-bold uppercase tracking-[0.08em] text-teal">Analytic unit</p>
                <p class="mt-1 text-base font-semibold text-navy">Developmental period x domain</p>
              </div>
              <div>
                <p class="text-sm font-bold uppercase tracking-[0.08em] text-teal">Overlay</p>
                <p class="mt-1 text-base font-semibold text-navy">Exposure, mechanism, outcome, evidence, priority</p>
              </div>
              <div>
                <p class="text-sm font-bold uppercase tracking-[0.08em] text-teal">Output</p>
                <p class="mt-1 text-base font-semibold text-navy">A research priority map for AI and childhood</p>
              </div>
            </div>

            <div class="flex flex-wrap gap-2">
              {
                [
                  ["#roadmap-goal", "Roadmap Goal"],
                  ["#bottlenecks", "Bottlenecks"],
                  ["#field-map", "Field Map"],
                  ["#priority-portfolio", "Priority Portfolio"],
                  ["#catalytic-programs", "Catalytic Programs"]
                ].map(([href, label]) => (
                  <a
                    href={href}
                    class="border border-navy px-3 py-2 text-sm font-bold text-navy transition hover:bg-navy hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-teal"
                  >
                    {label}
                  </a>
                ))
              }
            </div>
          </div>
        </section>

        <section id="why" class="section-panel">
          <p class="section-kicker">02 / Why this matters</p>
          <h2 class="section-title mt-4">AI is not screen time 2.0.</h2>
          <div class="mt-8 grid gap-8 lg:grid-cols-[minmax(0,1fr)_360px]">
            <div class="space-y-6">
              <p class="section-lede">
                AI can act as tutor, companion, media environment, feedback system, data collector, and institutional infrastructure. That makes the developmental question broader than usage minutes or device access.
              </p>
              <FramingNote />
            </div>
            <div class="content-card p-6">
              <p class="text-sm font-bold uppercase tracking-[0.08em] text-clay">Decision lens</p>
              <p class="mt-4 text-2xl font-bold leading-tight text-navy">
                The question is how AI changes the developmental environment across age, context, and time.
              </p>
              <p class="mt-4 text-sm leading-6 text-slate-600">
                A useful research map separates baseline child development from AI-specific mechanisms. That keeps product claims, classroom debates, and policy concerns attached to measurable developmental outcomes.
              </p>
            </div>
          </div>
        </section>

        <section id="roadmap-goal" class="section-panel">
          <p class="section-kicker">03 / Roadmap Goal</p>
          <h2 class="section-title mt-4">Make the roadmap target explicit before mapping the terrain.</h2>
          <p class="section-lede mt-6">
            Scientific roadmaps are most useful when they state a concrete stretch goal, then work backward to the capabilities, infrastructure, and coordination needed to reach it.
          </p>

          <div class="roadmap-goal mt-10">
            <div class="roadmap-goal-main">
              <p class="text-sm font-black uppercase tracking-[0.08em] text-ochre">Central roadmap question</p>
              <p class="mt-4 text-2xl font-bold leading-tight text-navy lg:text-3xl">
                What research infrastructure would let us rigorously evaluate AI's effects on child development over the next 3-5 years?
              </p>
              <p class="mt-5 text-sm leading-6 text-slate-600">
                The field does not only need more studies. It needs shared measurement, inspectable systems, longitudinal designs, and a way to turn scattered evidence into coordinated research programs.
              </p>
            </div>
            <div class="roadmap-goal-grid">
              {
                roadmapGoalPillars.map((pillar) => (
                  <article class="content-card p-5">
                    <p class="text-sm font-black uppercase tracking-[0.08em] text-teal">{pillar.label}</p>
                    <h3 class="mt-3 text-xl font-bold text-navy">{pillar.title}</h3>
                    <p class="mt-3 text-sm leading-6 text-slate-600">{pillar.body}</p>
                  </article>
                ))
              }
            </div>
          </div>
        </section>

        <section id="bottlenecks" class="section-panel">
          <p class="section-kicker">04 / Core Bottlenecks</p>
          <h2 class="section-title mt-4">The roadmap is organized around what currently blocks good evidence.</h2>
          <p class="section-lede mt-6">
            The key question is not which topic is most interesting in isolation. It is which bottleneck, if solved, unlocks better research across many downstream child-AI questions.
          </p>

          <div class="bottleneck-grid mt-10">
            {
              bottlenecks.map((bottleneck, index) => (
                <article class="bottleneck-card">
                  <div class="bottleneck-index">{String(index + 1).padStart(2, "0")}</div>
                  <div>
                    <h3>{bottleneck.title}</h3>
                    <p><strong>Current constraint:</strong> {bottleneck.current}</p>
                    <p><strong>What it unlocks:</strong> {bottleneck.unlock}</p>
                  </div>
                </article>
              ))
            }
