  <script>
    const densityEvidenceData = document.querySelector<HTMLScriptElement>("#density-evidence-data");
    const densityEvidence = densityEvidenceData?.textContent ? JSON.parse(densityEvidenceData.textContent) : [];
    const evidenceById = new Map(densityEvidence.map((cell: any) => [cell.id, cell]));
    const evidenceButtons = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-evidence-cell]"));
    const evidenceInspector = document.querySelector<HTMLElement>("[data-evidence-inspector]");
    const evidenceCollapseButton = document.querySelector<HTMLButtonElement>("[data-evidence-collapse]");
    const evidenceBody = document.querySelector<HTMLElement>("[data-evidence-body]");
    let selectedEvidenceCellId: string | null = null;
    let hasOpenedEvidenceInspector = false;

    const clearElement = (element: Element | null) => {
      if (!element) return;
      element.replaceChildren();
    };

    const appendText = (parent: Element, tag: string, text: string, className?: string) => {
      const element = document.createElement(tag);
      if (className) element.className = className;
      element.textContent = text;
      parent.appendChild(element);
      return element;
    };

    const renderEvidenceSources = (container: Element | null, sources: any[]) => {
      clearElement(container);
      if (!container) return;

      sources.forEach((source) => {
        const link = document.createElement("a");
        link.href = source.url;
        link.target = "_blank";
        link.rel = "noreferrer";
        link.className = "evidence-source-card";

        appendText(link, "span", `${source.organization}${source.year ? ` · ${source.year}` : ""}`, "evidence-source-meta");
        appendText(link, "strong", source.title);
        appendText(link, "span", source.evidenceRole, "evidence-source-role");
        container.appendChild(link);
      });
    };

    const renderEvidenceCell = (cellId: string | null) => {
      if (!cellId || !evidenceInspector) return;

      const cell = evidenceById.get(cellId);
      if (!cell) return;

      selectedEvidenceCellId = cellId;
      hasOpenedEvidenceInspector = true;
      evidenceInspector.hidden = false;
      evidenceInspector.classList.remove("is-folded");
      if (evidenceBody) evidenceBody.hidden = false;
      if (evidenceCollapseButton) {
        evidenceCollapseButton.textContent = "Fold evidence";
        evidenceCollapseButton.setAttribute("aria-expanded", "true");
      }

      evidenceButtons.forEach((button) => {
        const isSelected = button.getAttribute("data-evidence-cell") === cellId;
        button.classList.toggle("is-selected", isSelected);
        button.setAttribute("aria-pressed", String(isSelected));
      });

      const title = evidenceInspector.querySelector<HTMLElement>("[data-evidence-title]");
      const summary = evidenceInspector.querySelector<HTMLElement>("[data-evidence-summary]");
      const tier = evidenceInspector.querySelector<HTMLElement>("[data-evidence-tier]");
      const composite = evidenceInspector.querySelector<HTMLElement>("[data-evidence-composite]");
      const confidence = evidenceInspector.querySelector<HTMLElement>("[data-evidence-confidence]");
      const subscores = evidenceInspector.querySelector<HTMLElement>("[data-evidence-subscores]");
      const sources = evidenceInspector.querySelector<HTMLElement>("[data-evidence-sources]");
      const caveat = evidenceInspector.querySelector<HTMLElement>("[data-evidence-caveat]");
      const validation = evidenceInspector.querySelector<HTMLElement>("[data-evidence-validation]");
      const query = evidenceInspector.querySelector<HTMLElement>("[data-evidence-query]");

      if (title) title.textContent = `${cell.period} x ${cell.domain}`;
      if (summary) summary.textContent = cell.summary;
      if (tier) tier.textContent = `Tier ${cell.tier}: ${cell.tierLabel}`;
      if (composite) composite.textContent = `Composite ${cell.composite}/5`;
      if (confidence) confidence.textContent = cell.confidence;
      if (caveat) caveat.textContent = cell.caveat;
      if (query) query.textContent = cell.auditQuery;

      clearElement(subscores);
      cell.subscores.forEach((subscore: any) => {
        if (!subscores) return;

        const card = document.createElement("article");
        card.className = "subscore-card";

        const header = document.createElement("div");
        header.className = "subscore-card-header";
        appendText(header, "h4", subscore.label);
        appendText(header, "span", `${subscore.score}/5`);
        card.appendChild(header);

        appendText(card, "p", `${Math.round(subscore.weight * 100)}% weight · weighted contribution ${subscore.weighted}`, "subscore-weight");
        appendText(card, "p", subscore.question, "subscore-question");
        appendText(card, "p", subscore.rationale, "subscore-rationale");

        const sourceWrap = document.createElement("div");
        sourceWrap.className = "subscore-sources";
        subscore.sources.forEach((source: any) => {
          const link = document.createElement("a");
          link.href = source.url;
          link.target = "_blank";
          link.rel = "noreferrer";
          link.textContent = source.title;
          sourceWrap.appendChild(link);
        });
        card.appendChild(sourceWrap);
        subscores.appendChild(card);
      });

      renderEvidenceSources(sources, cell.sources);

      clearElement(validation);
      cell.validationNeeds.forEach((need: string) => {
        if (!validation) return;
        appendText(validation, "li", need);
      });
    };

    if (evidenceButtons.length > 0) {
      evidenceButtons.forEach((button) => {
        button.addEventListener("click", () => {
          renderEvidenceCell(button.getAttribute("data-evidence-cell"));
        });
      });

      evidenceCollapseButton?.addEventListener("click", () => {
        if (!evidenceInspector || !evidenceBody) return;

        const willFold = !evidenceInspector.classList.contains("is-folded");
        evidenceInspector.classList.toggle("is-folded", willFold);
        evidenceBody.hidden = willFold;
        evidenceCollapseButton.textContent = willFold ? "Open evidence" : "Fold evidence";
        evidenceCollapseButton.setAttribute("aria-expanded", String(!willFold));

        if (!hasOpenedEvidenceInspector && !willFold) {
          renderEvidenceCell(selectedEvidenceCellId || evidenceButtons[0].getAttribute("data-evidence-cell"));
        }
      });
    }

    const densityTabsRoot = document.querySelector<HTMLElement>("[data-density-tabs]");

    if (densityTabsRoot) {
      const tabs = Array.from(densityTabsRoot.querySelectorAll<HTMLButtonElement>("[data-density-tab]"));
      const panels = Array.from(densityTabsRoot.querySelectorAll<HTMLElement>("[data-density-panel]"));

      const activateTab = (key: string | null) => {
        if (!key) return;

        tabs.forEach((tab) => {
          const isActive = tab.getAttribute("data-density-tab") === key;
          tab.classList.toggle("is-active", isActive);
          tab.setAttribute("aria-selected", String(isActive));
          tab.setAttribute("tabindex", isActive ? "0" : "-1");
        });

        panels.forEach((panel) => {
          panel.hidden = panel.getAttribute("data-density-panel") !== key;
        });
      };

      tabs.forEach((tab, index) => {
        tab.addEventListener("click", () => {
          activateTab(tab.getAttribute("data-density-tab"));
        });

        tab.addEventListener("keydown", (event) => {
          if (!["ArrowLeft", "ArrowRight", "Home", "End"].includes(event.key)) {
            return;
          }

          event.preventDefault();
          const lastIndex = tabs.length - 1;
          let nextIndex = index;

          if (event.key === "ArrowRight") nextIndex = index === lastIndex ? 0 : index + 1;
          if (event.key === "ArrowLeft") nextIndex = index === 0 ? lastIndex : index - 1;
          if (event.key === "Home") nextIndex = 0;
          if (event.key === "End") nextIndex = lastIndex;

          const nextTab = tabs[nextIndex];
          activateTab(nextTab.getAttribute("data-density-tab"));
          nextTab.focus();
        });
      });
    }

    const citationLibrary = document.querySelector<HTMLElement>("[data-citation-library]");

    if (citationLibrary) {
      const searchInput = citationLibrary.querySelector<HTMLInputElement>("[data-library-search]");
      const filterButtons = Array.from(citationLibrary.querySelectorAll<HTMLButtonElement>("[data-library-filter]"));
      const cards = Array.from(document.querySelectorAll<HTMLElement>("[data-citation-card]"));
      const emptyState = document.querySelector<HTMLElement>("[data-library-empty]");
      let activeCategory = "All";

      const applyLibraryFilters = () => {
        if (!searchInput) return;

        const query = searchInput.value.trim().toLowerCase();
        let visibleCount = 0;

        cards.forEach((card) => {
          const category = card.getAttribute("data-category");
          const searchText = card.getAttribute("data-search-text") || "";
          const matchesCategory = activeCategory === "All" || category === activeCategory;
          const matchesSearch = query === "" || searchText.includes(query);
          const isVisible = matchesCategory && matchesSearch;

          card.hidden = !isVisible;
          if (isVisible) visibleCount += 1;
        });

        if (emptyState) {
          emptyState.hidden = visibleCount > 0;
        }
      };

      filterButtons.forEach((button) => {
        button.addEventListener("click", () => {
          activeCategory = button.getAttribute("data-library-filter") || "All";

          filterButtons.forEach((filterButton) => {
            const isActive = filterButton === button;
            filterButton.classList.toggle("is-active", isActive);
            filterButton.setAttribute("aria-pressed", String(isActive));
          });

          applyLibraryFilters();
        });
      });

      searchInput?.addEventListener("input", applyLibraryFilters);
    }
  </script>
</BaseLayout>
